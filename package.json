    "@unhead/vue": "^3.1.1",
    "daisyui": "^5.5.20",
    "drizzle-orm": "^0.45.2",
    "eslint": "^10.4.0",
    "nuxt": "^4.4.6",
    "tailwindcss": "^4.3.0",
    "three": "^0.184.0",
    "vue": "^3.5.35",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "^2.1.152",
    "@trunkio/launcher": "^1.3.4",
    "@types/node": "^25.9.1",
    "drizzle-kit": "^0.31.10",
    "nitro-cloudflare-dev": "^0.2.2",
    "nitropack": "^2.13.4",
    "node-gyp": "^12.3.0",
    "npm-run-all2": "^9.0.1",
    "prettier": "^3.8.3",
    "wrangler": "^4.95.0"
  },
  "name": "ambio",
  "packageManager": "bun@1.3.14",
  "private": true,
  "scripts": {
    "build": "bun run nuxt build",
    "cf-typegen": "bun run wrangler types",
    "db:generate": "bun run drizzle-kit generate",
    "db:migrate:local": "bun run wrangler d1 migrations apply ambio-systems --local",
    "db:migrate:remote": "bun run wrangler d1 migrations apply ambio-systems --remote",
    "db:studio": "bun run drizzle-kit studio",
    "deploy": "bun run run-s build deploy:wrangler",
    "deploy:wrangler": "bun run wrangler deploy",
    "dev": "bun run run-s build dev:wrangler",
    "dev:wrangler": "bun run wrangler dev",
    "format": "bun run run-s format:prettier format:trunk",
    "format:prettier": "bun run prettier --write .",
    "format:trunk": "bun run trunk fmt -a",
    "generate": "bun run nuxt generate",
    "postinstall": "bun run run-s prepare cf-typegen format",
    "prepare": "bun run nuxt prepare"
  },
  "trustedDependencies": [
    "@anthropic-ai/claude-code",
    "@parcel/watcher",
    "esbuild",
    "sharp",
    "unrs-resolver",
    "workerd"
  ],
  "type": "module"
}
